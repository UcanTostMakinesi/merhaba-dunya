    <!-- ZAFER / OYUN KAZANILDI EKRANI -->
    <div id="victoryMenu" class="absolute inset-0 bg-black/95 flex flex-col items-center justify-center text-white z-20 px-4 text-center hidden">
        <h1 class="text-5xl md:text-7xl font-black tracking-widest neon-glow-gold text-yellow-400 mb-2 animate-bounce">BÜYÜK ZAFER</h1>
        <h2 class="text-xl md:text-2xl font-bold text-emerald-400 uppercase tracking-widest mb-8">Karanlık Güçler Yenildi, Galaksi Kurtarıldı!</h2>

        <div class="bg-gray-900/60 border border-yellow-500/40 p-8 rounded-2xl max-w-sm w-full mb-8 space-y-4">
